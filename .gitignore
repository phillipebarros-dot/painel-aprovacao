.env
.env.*
!.env.example

# ===================================================
# n8n WORKFLOWS — contêm IDs de credenciais OAuth
# (BigQuery, Google Drive, Sheets, SMTP)
# Se vazar: atacante sabe quais serviços estão conectados
# ===================================================
n8n/
!n8n/Painel de aprovacao l TESTE - FLUXO COMPLETO.json

# ===================================================
# PENTEST / SEGURANÇA — NUNCA versionar
# Estes arquivos revelam vulnerabilidades conhecidas,
# payloads de ataque e resultados de varredura.
# Se vazar: atacante tem mapa completo de onde atacar
# ===================================================
pentest_full.py
pentest_results.json
sqlmap_request.txt
fix_security_headers.py

